    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.0",
    "three": "^0.179.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.179.0",
    "jsdom": "^26.0.0",
